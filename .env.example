# ─── apps/api ───
# Секрет для подписи JWT (HS256). В проде — длинная случайная строка.
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
# Разрешённые CORS-источники (через запятую): admin-панель и dev-серверы
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Порт API
PORT=3001
# PostgreSQL (Supabase/Neon). Если не задан — используется встроенный PGlite (dev/test).
# DATABASE_URL=postgres://user:pass@host:5432/dbname
